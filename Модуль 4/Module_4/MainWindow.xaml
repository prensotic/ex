<Window x:Class="Module_4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Module_4"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="400">
    <Grid Background="#F5F5F5">

        <Border Width="320"
                Padding="20"
                Background="White"
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Авторизация"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Логин"
                           FontSize="14"/>

                <TextBox x:Name="tbUsername"
                         Height="35"
                         Margin="0,5,0,15"
                         FontSize="14"/>

                <TextBlock Text="Пароль"
                           FontSize="14"/>

                <PasswordBox x:Name="pbPassword"
                             Height="35"
                             Margin="0,5,0,20"
                             FontSize="14"/>

                <TextBlock Text="Соберите капчу"
                           FontWeight="Bold"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <UniformGrid Rows="2"
                             Columns="2"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,20">

                    <Border Margin="5"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Image x:Name="img1"
                               Width="120"
                               Height="120"
                               Stretch="Fill"
                               MouseDown="Image_Click"/>
                    </Border>

                    <Border Margin="5"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Image x:Name="img2"
                               Width="120"
                               Height="120"
                               Stretch="Fill"
                               MouseDown="Image_Click"/>
                    </Border>

                    <Border Margin="5"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Image x:Name="img3"
                               Width="120"
                               Height="120"
                               Stretch="Fill"
                               MouseDown="Image_Click"/>
                    </Border>

                    <Border Margin="5"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Image x:Name="img4"
                               Width="120"
                               Height="120"
                               Stretch="Fill"
                               MouseDown="Image_Click"/>
                    </Border>

                </UniformGrid>

                <Button Content="Войти"
                        Height="40"
                        FontSize="16"
                        Click="Login_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>
